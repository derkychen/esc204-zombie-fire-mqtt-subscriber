    {
      "datasource": {
        "type": "influxdb",
        "uid": "${DS_INFLUXDB}"
      },
      "description": "BME680 temperature by depth level.",
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 12,
            "showPoints": "never",
            "spanNulls": true
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "id": 3,
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["lastNotNull", "min", "max"]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "influxdb",
            "uid": "${DS_INFLUXDB}"
          },
          "format": "time_series",
          "queryType": "sql",
          "rawQuery": true,
          "rawSql": "SELECT time AS time, device_id || ' level ' || CAST(level AS STRING) || ' temp' AS metric, temperature_c AS value\nFROM bme680\nWHERE $__timeFilter(time)\n  AND device_id IN (${device:sqlstring})\n  AND level IN (${level:sqlstring})\nORDER BY time",
          "refId": "A"
        }
      ],
      "title": "BME680 Temperature by Level",
      "type": "timeseries"
    },
